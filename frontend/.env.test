# Test Environment Configuration
VITE_API_BASE_URL=http://test-gateway:8080/api
VITE_WS_BASE_URL=ws://test-gateway:8080/ws
VITE_NODE_ENV=test

# Feature Flags
VITE_ENABLE_WEBSOCKET=false
VITE_ENABLE_FILE_UPLOAD=true
VITE_ENABLE_NOTIFICATIONS=false

# Cache Configuration (minimal caching for tests)
VITE_CACHE_TTL=1000

# File Upload Configuration
VITE_MAX_FILE_SIZE=1048576
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png

# Retry Configuration
VITE_MAX_RETRIES=1
VITE_RETRY_DELAY=100

# Debug Mode
VITE_DEBUG=true

# Service URLs (for test environment)
VITE_AUTH_SERVICE_URL=http://test-auth-service:8081
VITE_USER_SERVICE_URL=http://test-user-service:8082
VITE_QUEST_SERVICE_URL=http://test-quest-service:8083
VITE_GAME_SERVICE_URL=http://test-game-service:8084
VITE_TEAM_SERVICE_URL=http://test-team-service:8085
VITE_NOTIFICATION_SERVICE_URL=http://test-notification-service:8086
VITE_STATISTICS_SERVICE_URL=http://test-statistics-service:8087
VITE_FILE_SERVICE_URL=http://test-file-service:8088

# Test Configuration
VITE_MOCK_API=false
VITE_SEED_TEST_DATA=true