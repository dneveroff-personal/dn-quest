# ===========================================
# DN Quest - Переменные окружения
# ===========================================

# --- База данных PostgreSQL ---
POSTGRES_USER=dn
POSTGRES_PASSWORD=dn
POSTGRES_DB=dnqdb
POSTGRES_PORT=5432
SPRING_DB_USER=dn
SPRING_DB_PASS=dn

# --- Spring Boot Backend ---
SPRING_PROFILES_ACTIVE=dev
DDL_AUTO=update
SHOW_SQL=false
FORMAT_SQL=true

# --- JWT Аутентификация ---
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production-min-256-bits
JWT_EXPIRATION_MS=86400000

# --- Telegram Bot ---
BOT_TOKEN=your-telegram-bot-token-here

# --- Frontend ---
NODE_ENV=development
VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_TITLE=DN Quest

# --- Порты ---
BACKEND_PORT=8080
FRONTEND_PORT=5173
DEBUG_PORT=5004

# --- Логирование ---
LOG_LEVEL=INFO
LOG_LEVEL_APP=DEBUG

# --- Actuator ---
ACTUATOR_ENDPOINTS=health,info,metrics
HEALTH_SHOW_DETAILS=when-authorized

# --- PgAdmin (опционально) ---
PGADMIN_EMAIL=admin@localhost.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- Redis (опционально) ---
REDIS_PORT=6379

# --- Qdrant (опционально) ---
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Production (раскомментировать для продакшена) ---
# SPRING_PROFILES_ACTIVE=prod
# NODE_ENV=production
# JWT_SECRET=production-secret-key-at-least-256-bits-long
# BOT_TOKEN=production-telegram-bot-token
# LOG_LEVEL=INFO
# LOG_LEVEL_APP=INFO
# ACTUATOR_ENDPOINTS=health,info,metrics
# HEALTH_SHOW_DETAILS=never

# --- Docker ---
# DOCKERFILE=Dockerfile
# FRONTEND_TARGET=production

# --- Nginx (для production) ---
# NGINX_PORT=443
# NGINX_HTTP_PORT=80

# --- Admin user configuration ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin