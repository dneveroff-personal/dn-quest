# ===========================================
# DN Quest - Testing Environment
# ===========================================

# --- Global Configuration ---
COMPOSE_PROJECT_NAME=dn-quest-test
SPRING_PROFILES_ACTIVE=test
ENVIRONMENT=testing

# --- Database Configuration ---
POSTGRES_USER=dn_test
POSTGRES_PASSWORD=dn_test
POSTGRES_DB_TEMPLATE=dnquest_test_{service}

# Service-specific databases
POSTGRES_AUTH_DB=dnquest_test_auth
POSTGRES_USERS_DB=dnquest_test_users
POSTGRES_QUESTS_DB=dnquest_test_quests
POSTGRES_GAME_DB=dnquest_test_game
POSTGRES_TEAMS_DB=dnquest_test_teams
POSTGRES_NOTIFICATIONS_DB=dnquest_test_notifications
POSTGRES_STATISTICS_DB=dnquest_test_statistics
POSTGRES_FILES_DB=dnquest_test_files

# Database ports
POSTGRES_AUTH_PORT=5432
POSTGRES_USERS_PORT=5433
POSTGRES_QUESTS_PORT=5434
POSTGRES_GAME_PORT=5435
POSTGRES_TEAMS_PORT=5436
POSTGRES_NOTIFICATIONS_PORT=5437
POSTGRES_STATISTICS_PORT=5438
POSTGRES_FILES_PORT=5439

# --- Service Ports ---
API_GATEWAY_PORT=8080
AUTHENTICATION_SERVICE_PORT=8081
USER_MANAGEMENT_SERVICE_PORT=8082
QUEST_MANAGEMENT_SERVICE_PORT=8083
GAME_ENGINE_SERVICE_PORT=8084
TEAM_MANAGEMENT_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8086
STATISTICS_SERVICE_PORT=8087
FILE_STORAGE_SERVICE_PORT=8088

# --- Infrastructure Ports ---
REDIS_PORT=6379
KAFKA_PORT=9092
KAFKA_UI_PORT=8089
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
PGADMIN_PORT=5050

# --- JWT Configuration ---
JWT_SECRET=dnQuestTestSecretKeyForJWTTokenGenerationAndValidation2024
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=7200000

# --- Kafka Configuration ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# --- Redis Configuration ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO Configuration ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=dn-quest-test-files

# --- Email Configuration ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password
SMTP_FROM_EMAIL=noreply@dnquest.test

# --- Telegram Bot Configuration ---
TELEGRAM_BOT_TOKEN=your-test-telegram-bot-token
TELEGRAM_BOT_USERNAME=dnquest_test_bot

# --- Frontend Configuration ---
VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_TITLE=DN Quest (Testing)
VITE_APP_VERSION=1.0.0-test

# --- Logging Configuration ---
LOG_LEVEL=DEBUG
LOGGING_LEVEL_ROOT=DEBUG
LOGGING_LEVEL_DN_QUEST=DEBUG

# --- Actuator Configuration ---
ACTUATOR_ENDPOINTS=health,info,metrics,prometheus,env,configprops
HEALTH_SHOW_DETAILS=always

# --- Monitoring ---
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true

# --- Security ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*

# --- File Storage ---
MAX_FILE_SIZE=100MB
ALLOWED_FILE_TYPES=*

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=10000

# --- Cache Configuration ---
CACHE_TTL=60
CACHE_MAX_SIZE=50

# --- Health Check Configuration ---
HEALTH_CHECK_INTERVAL=10s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=10

# --- Docker Configuration ---
DOCKER_REGISTRY=dn-quest
DOCKER_TAG=1.0.0-test
DOCKER_NETWORK=dn-quest-test-network

# --- Development Configuration ---
DEBUG_ENABLED=true
HOT_RELOAD=true
DEVTOOLS_ENABLED=true

# --- Admin User Configuration ---
ADMIN_USERNAME=test_admin
ADMIN_PASSWORD=test_admin
ADMIN_EMAIL=admin@dnquest.test

# --- External Services ---
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id-test
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret-test

# --- Testing Configuration ---
TEST_DATA_ENABLED=true
TEST_DATA_CLEANUP_ENABLED=true
TEST_DATA_CLEANUP_SCHEDULE=0 2 * * *
INTEGRATION_TESTS_ENABLED=true
LOAD_TESTS_ENABLED=true
PERFORMANCE_TESTS_ENABLED=true

# --- Database Testing Configuration ---
DATABASE_CLEANUP_BETWEEN_TESTS=true
DATABASE_SEED_DATA=true
DATABASE_MIGRATION_AUTO_RUN=true

# --- Mock Services Configuration ---
MOCK_EXTERNAL_SERVICES=true
MOCK_EMAIL_SERVICE=true
MOCK_TELEGRAM_BOT=true
MOCK_FILE_STORAGE=true

# --- Test Data Configuration ---
TEST_USERS_COUNT=100
TEST_QUESTS_COUNT=50
TEST_TEAMS_COUNT=20
TEST_GAME_SESSIONS_COUNT=30

# --- Load Testing Configuration ---
LOAD_TEST_CONCURRENT_USERS=50
LOAD_TEST_DURATION=300
LOAD_TEST_RAMP_UP_TIME=60

# --- Performance Testing Configuration ---
PERFORMANCE_TEST_RESPONSE_TIME_THRESHOLD=2000
PERFORMANCE_TEST_THROUGHPUT_THRESHOLD=100
PERFORMANCE_TEST_ERROR_RATE_THRESHOLD=5

# --- Security Testing Configuration ---
SECURITY_TEST_ENABLED=true
SECURITY_TEST_SCAN_ENDPOINTS=true
SECURITY_TEST_VULNERABILITY_SCAN=true

# --- Test Reporting Configuration ---
TEST_REPORTS_ENABLED=true
TEST_REPORTS_FORMAT=html,json
TEST_REPORTS_OUTPUT_DIR=test-reports
COVERAGE_REPORTS_ENABLED=true
COVERAGE_REPORTS_THRESHOLD=80

# --- CI/CD Configuration ---
CI_CD_ENABLED=true
CI_CD_BUILD_NUMBER=${BUILD_NUMBER:-0}
CI_CD_BRANCH=${BRANCH_NAME:-local}
CI_CD_COMMIT=${COMMIT_SHA:-local}

# --- Test Environment Isolation ---
TEST_ISOLATION_ENABLED=true
TEST_NETWORK_ISOLATION=true
TEST_RESOURCE_LIMITS_ENABLED=true

# --- Test Database Configuration ---
TEST_DATABASE_HOST=postgres-test
TEST_DATABASE_POOL_SIZE=5
TEST_DATABASE_CONNECTION_TIMEOUT=30

# --- Test Kafka Configuration ---
TEST_KAFKA_TOPICS_PREFIX=test_
TEST_KAFKA_CONSUMER_GROUP_PREFIX=test_
TEST_KAFKA_AUTO_OFFSET_RESET=earliest

# --- Test Redis Configuration ---
TEST_REDIS_DATABASE=1
TEST_REDIS_KEY_PREFIX=test:
TEST_REDIS_TTL=3600